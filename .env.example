# === N8N ===
N8N_ENCRYPTION_KEY=your-64-char-hex-key-here
N8N_DB_PASSWORD=your-postgres-password

# === TAILSCALE ===
# Erstelle einen Key auf login.tailscale.com → Settings → Keys
TAILSCALE_AUTHKEY=tskey-auth-xxxxx

# === GRAFANA ===
GRAFANA_USER=admin
GRAFANA_PASSWORD=your-grafana-password

# === CODE SERVER ===
CODE_PASSWORD=your-code-server-password

# === EVOLUTION API ===
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_DB_PASSWORD=your-evolution-db-password
EVOLUTION_URL=http://evolution-api:8080

# === GYM TRACKER ===
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx
GEMINI_API_KEY=your-gemini-key
JWT_SECRET=your-64-byte-hex-secret
LEGACY_ADMIN_USERNAME=admin
LEGACY_ADMIN_PASSWORD=your-password
GYM_INVITE_CODE=your-invite-code
RESEND_API_KEY=

# === INFISICAL (Secrets Manager) ===
# Generiere mit: openssl rand -hex 16 (ENCRYPTION_KEY) und openssl rand -base64 32 (AUTH_SECRET)
INFISICAL_ENCRYPTION_KEY=your-32-char-hex-key
INFISICAL_AUTH_SECRET=your-base64-auth-secret
INFISICAL_DB_PASSWORD=your-infisical-db-password
INFISICAL_REDIS_PASSWORD=your-infisical-redis-password
# Machine Identity Token für gym-tracker-next (nach Setup in Infisical UI generieren)
INFISICAL_TOKEN=

# === DUPLICATI ===
DUPLICATI_PASSWORD=your-duplicati-password
DUPLICATI_ENCRYPTION_KEY=your-encryption-key

# === BACKUP PC ===
BACKUP_PC_USER=your-pc-username
GPG_PASSPHRASE=your-strong-gpg-passphrase

# === CLOUDFLARE ===
CLOUDFLARE_TUNNEL_TOKEN=your-cloudflare-tunnel-token

# === SAMBA (optional) ===
SAMBA_USER=milan
SAMBA_PASSWORD=your-samba-password

# === TTYD (optional) ===
TTYD_PASSWORD=your-ttyd-password
