{
  "title": "🍓 Raspberry Pi System",
  "uid": "rpi-system",
  "tags": ["system", "rpi"],
  "timezone": "Europe/Berlin",
  "refresh": "30s",
  "time": {"from": "now-3h", "to": "now"},
  "panels": [
    {
      "id": 1, "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "title": "CPU Auslastung",
      "type": "stat",
      "datasource": {"uid": "prometheus"},
      "targets": [{"expr": "100 - (avg by(instance)(rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)", "legendFormat": "CPU %"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 60}, {"color": "red", "value": 85}]}}}
    },
    {
      "id": 2, "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "title": "RAM Auslastung",
      "type": "stat",
      "datasource": {"uid": "prometheus"},
      "targets": [{"expr": "100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))", "legendFormat": "RAM %"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}}}
    },
    {
      "id": 3, "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "title": "Disk Auslastung",
      "type": "stat",
      "datasource": {"uid": "prometheus"},
      "targets": [{"expr": "100 - ((node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"}) * 100)", "legendFormat": "Disk %"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 75}, {"color": "red", "value": 90}]}}}
    },
    {
      "id": 4, "gridPos": {"h": 4, "w": 4, "x": 12, "y": 0},
      "title": "CPU Temperatur",
      "type": "stat",
      "datasource": {"uid": "prometheus"},
      "targets": [{"expr": "node_thermal_zone_temp{zone=\"0\"}", "legendFormat": "Temp °C"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "fieldConfig": {"defaults": {"unit": "celsius", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 60}, {"color": "red", "value": 75}]}}}
    },
    {
      "id": 5, "gridPos": {"h": 4, "w": 4, "x": 16, "y": 0},
      "title": "RAM frei",
      "type": "stat",
      "datasource": {"uid": "prometheus"},
      "targets": [{"expr": "node_memory_MemAvailable_bytes", "legendFormat": "Frei"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value"},
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "id": 6, "gridPos": {"h": 4, "w": 4, "x": 20, "y": 0},
      "title": "Uptime",
      "type": "stat",
      "datasource": {"uid": "prometheus"},
      "targets": [{"expr": "time() - node_boot_time_seconds", "legendFormat": "Uptime"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value"},
      "fieldConfig": {"defaults": {"unit": "dtdurations"}}
    },
    {
      "id": 10, "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "title": "CPU Auslastung (Verlauf)",
      "type": "timeseries",
      "datasource": {"uid": "prometheus"},
      "targets": [
        {"expr": "100 - (avg by(instance)(rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)", "legendFormat": "CPU gesamt %"},
        {"expr": "avg by(cpu)(rate(node_cpu_seconds_total{mode=\"user\"}[2m])) * 100", "legendFormat": "Core {{cpu}} user"}
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "custom": {"lineWidth": 2, "fillOpacity": 10}}}
    },
    {
      "id": 11, "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "title": "RAM Verlauf",
      "type": "timeseries",
      "datasource": {"uid": "prometheus"},
      "targets": [
        {"expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes", "legendFormat": "Benutzt"},
        {"expr": "node_memory_MemAvailable_bytes", "legendFormat": "Verfügbar"},
        {"expr": "node_memory_Buffers_bytes + node_memory_Cached_bytes", "legendFormat": "Cache/Buffer"}
      ],
      "fieldConfig": {"defaults": {"unit": "bytes", "custom": {"lineWidth": 2, "fillOpacity": 15, "stacking": {"mode": "none"}}}}
    },
    {
      "id": 12, "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "title": "Netzwerk I/O",
      "type": "timeseries",
      "datasource": {"uid": "prometheus"},
      "targets": [
        {"expr": "rate(node_network_receive_bytes_total{device=\"eth0\"}[2m])", "legendFormat": "↓ Empfangen"},
        {"expr": "rate(node_network_transmit_bytes_total{device=\"eth0\"}[2m])", "legendFormat": "↑ Gesendet"}
      ],
      "fieldConfig": {"defaults": {"unit": "Bps", "custom": {"lineWidth": 2, "fillOpacity": 10}}}
    },
    {
      "id": 13, "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "title": "Disk I/O",
      "type": "timeseries",
      "datasource": {"uid": "prometheus"},
      "targets": [
        {"expr": "rate(node_disk_read_bytes_total{device=\"mmcblk0\"}[2m])", "legendFormat": "↓ Lesen"},
        {"expr": "rate(node_disk_written_bytes_total{device=\"mmcblk0\"}[2m])", "legendFormat": "↑ Schreiben"}
      ],
      "fieldConfig": {"defaults": {"unit": "Bps", "custom": {"lineWidth": 2, "fillOpacity": 10}}}
    },
    {
      "id": 14, "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "title": "CPU Temperatur (Verlauf)",
      "type": "timeseries",
      "datasource": {"uid": "prometheus"},
      "targets": [
        {"expr": "node_thermal_zone_temp{zone=\"0\"}", "legendFormat": "CPU Temp °C"}
      ],
      "fieldConfig": {"defaults": {"unit": "celsius", "custom": {"lineWidth": 2, "fillOpacity": 15}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 60}, {"color": "red", "value": 75}]}}}
    },
    {
      "id": 15, "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "title": "Load Average",
      "type": "timeseries",
      "datasource": {"uid": "prometheus"},
      "targets": [
        {"expr": "node_load1", "legendFormat": "1m"},
        {"expr": "node_load5", "legendFormat": "5m"},
        {"expr": "node_load15", "legendFormat": "15m"}
      ],
      "fieldConfig": {"defaults": {"custom": {"lineWidth": 2}}}
    },
    {
      "id": 16, "gridPos": {"h": 8, "w": 24, "x": 0, "y": 28},
      "title": "Docker Container RAM",
      "type": "timeseries",
      "datasource": {"uid": "prometheus"},
      "targets": [
        {"expr": "container_memory_usage_bytes{name!=\"\", name!~\".*_init.*\"} / 1024 / 1024", "legendFormat": "{{name}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "megabytes", "custom": {"lineWidth": 1}}}
    }
  ],
  "schemaVersion": 38
}
